# ============================================================
# Chatisha Control Plane – Environment Example
# Used by: apps/control-plane
# Copy to apps/control-plane/.env and fill in your values
# ============================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chatisha

# Admin Dashboard Auth
ADMIN_PASSWORD=your-secure-admin-password

# Portal API Security (must match PORTAL_INTERNAL_KEY in web app)
PORTAL_INTERNAL_KEY=change-this-to-a-long-random-secret-key

# AI (Claude via Anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-...

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Paths
SESSIONS_PATH=./sessions
LOGS_PATH=./logs

# Worker Settings
RATE_LIMIT_MAX_PER_MINUTE=10
HEARTBEAT_INTERVAL_MS=30000
STALE_THRESHOLD_MINUTES=2
STALE_CHECK_INTERVAL_MS=60000

# Production: path to Chromium/Chrome binary for whatsapp-web.js
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
