# ============================================================
# DEPLOYMENT ARCHITECTURE
#
#   apps/web           → Vercel (Next.js frontend)
#   apps/control-plane → VPS (same server as workers — uses local PM2)
#   apps/worker        → VPS (PM2 + Puppeteer/Chrome)
#   Database           → Neon (hosted PostgreSQL — neon.tech, free tier)
#
# The control-plane MUST stay on the VPS because it spawns
# WhatsApp workers using PM2 on the local machine.
# ============================================================


# ============================================================
# VERCEL — set these in Vercel Dashboard → Settings → Env Vars
# ============================================================

# NextAuth
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=run-openssl-rand-base64-32-to-generate

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Add https://your-app.vercel.app/api/auth/callback/google as redirect URI
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Your VPS control-plane (expose port 3000 or put behind nginx)
CONTROL_PLANE_URL=http://YOUR_VPS_IP:3000

# Shared secret — must match PORTAL_INTERNAL_KEY on VPS
PORTAL_INTERNAL_KEY=change-this-to-a-strong-random-secret

# Neon database URL (get from neon.tech after creating project)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/flowhq?sslmode=require


# ============================================================
# VPS — apps/control-plane — update apps/control-plane/.env
# ============================================================

# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/flowhq?sslmode=require
# ADMIN_PASSWORD=your-strong-admin-password
# PORTAL_INTERNAL_KEY=same-value-as-vercel
# ANTHROPIC_API_KEY=sk-ant-api03-...
# NODE_ENV=production
# PORT=3000


# ============================================================
# VPS — apps/worker — injected automatically by provisioner via PM2
# (no manual setup needed — control-plane passes these per worker)
# ============================================================

# DATABASE_URL         <- injected from control-plane .env
# ANTHROPIC_API_KEY    <- injected from control-plane .env
# TENANT_ID            <- set per-worker by provisioner
# SESSIONS_PATH        <- set per-worker by provisioner
# RATE_LIMIT_MAX_PER_MINUTE=10
# HEARTBEAT_INTERVAL_MS=30000
# MEMORY_WARN_MB=400
# MEMORY_CRITICAL_MB=600
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
