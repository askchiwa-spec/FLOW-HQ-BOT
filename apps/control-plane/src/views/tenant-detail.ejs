<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chatisha Admin — <%= tenant.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #080d18; --bg-card: #0d1625; --bg-card2: #111c2e;
      --border: rgba(255,255,255,0.07); --primary: #10b981;
      --primary-dim: rgba(16,185,129,0.12); --primary-border: rgba(16,185,129,0.25);
      --secondary: #8b5cf6; --danger: #ef4444; --danger-dim: rgba(239,68,68,0.12);
      --warning: #f59e0b; --warning-dim: rgba(245,158,11,0.12);
      --text: #e2e8f0; --text-muted: #64748b; --text-dim: #94a3b8;
      --radius: 12px; --radius-sm: 8px;
    }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; }
    .sidebar { width: 240px; min-height: 100vh; background: var(--bg-card); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 10; }
    .logo { display: flex; align-items: center; gap: 12px; padding: 24px 20px; border-bottom: 1px solid var(--border); }
    .logo-icon { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, #10b981, #059669); display: flex; align-items: center; justify-content: center; font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 18px; color: white; flex-shrink: 0; box-shadow: 0 0 20px rgba(16,185,129,0.3); }
    .logo-text { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 16px; color: white; }
    .logo-sub { font-size: 10px; color: var(--text-muted); font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; }
    .nav { padding: 16px 12px; flex: 1; }
    .nav-label { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; padding: 0 8px; margin-bottom: 8px; margin-top: 16px; }
    .nav-link { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: var(--radius-sm); color: var(--text-dim); text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.15s; margin-bottom: 2px; border: 1px solid transparent; }
    .nav-link:hover { background: rgba(255,255,255,0.05); color: var(--text); }
    .nav-link.active { background: var(--primary-dim); color: var(--primary); border-color: var(--primary-border); }
    .nav-link svg { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar-footer { padding: 16px 20px; border-top: 1px solid var(--border); }
    .sidebar-footer p { font-size: 11px; color: var(--text-muted); }
    .main { margin-left: 240px; flex: 1; padding: 32px; min-height: 100vh; }
    .page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 28px; }
    .page-header-left h1 { font-family: 'Space Grotesk', sans-serif; font-size: 24px; font-weight: 700; color: white; }
    .page-header-left p { color: var(--text-muted); font-size: 14px; margin-top: 4px; }
    .back-link { display: inline-flex; align-items: center; gap: 6px; color: var(--text-muted); text-decoration: none; font-size: 13px; margin-bottom: 20px; transition: color 0.15s; }
    .back-link:hover { color: var(--primary); }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
    .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 20px; overflow: hidden; }
    .card-header { padding: 18px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .card-header h2 { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 600; color: white; }
    .card-body { padding: 24px; }
    .info-row { display: flex; align-items: flex-start; padding: 10px 0; border-bottom: 1px solid var(--border); gap: 16px; }
    .info-row:last-child { border-bottom: none; }
    .info-label { width: 130px; flex-shrink: 0; font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; padding-top: 2px; }
    .info-value { flex: 1; font-size: 14px; color: var(--text); font-family: monospace; word-break: break-all; }
    .info-value.normal { font-family: inherit; }
    .badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; letter-spacing: 0.03em; }
    .badge-new { background: rgba(100,116,139,0.15); color: #94a3b8; border: 1px solid rgba(100,116,139,0.2); }
    .badge-qr_pending { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.2); }
    .badge-active { background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
    .badge-paused { background: rgba(139,92,246,0.12); color: #8b5cf6; border: 1px solid rgba(139,92,246,0.2); }
    .badge-error { background: rgba(239,68,68,0.12); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
    .badge-connected { background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
    .badge-disconnected { background: rgba(100,116,139,0.1); color: #64748b; border: 1px solid rgba(100,116,139,0.15); }
    .badge-running { background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
    .badge-stopped { background: rgba(100,116,139,0.1); color: #64748b; border: 1px solid rgba(100,116,139,0.15); }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: var(--radius-sm); font-size: 13px; font-weight: 500; cursor: pointer; border: 1px solid transparent; text-decoration: none; transition: all 0.15s; font-family: inherit; }
    .btn-primary { background: var(--primary); color: white; border-color: var(--primary); }
    .btn-primary:hover { background: #059669; }
    .btn-ghost { background: rgba(255,255,255,0.05); color: var(--text-dim); border-color: var(--border); }
    .btn-ghost:hover { background: rgba(255,255,255,0.08); color: white; }
    .btn-success { background: var(--primary-dim); color: var(--primary); border-color: var(--primary-border); }
    .btn-success:hover { background: rgba(16,185,129,0.2); }
    .btn-danger { background: var(--danger-dim); color: var(--danger); border-color: rgba(239,68,68,0.25); }
    .btn-danger:hover { background: rgba(239,68,68,0.2); }
    .btn-warning { background: var(--warning-dim); color: var(--warning); border-color: rgba(245,158,11,0.25); }
    .btn-warning:hover { background: rgba(245,158,11,0.2); }
    .worker-actions { display: flex; gap: 8px; flex-wrap: wrap; padding-top: 16px; margin-top: 8px; border-top: 1px solid var(--border); }
    .qr-container { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 32px; min-height: 260px; }
    .qr-container img { max-width: 240px; border-radius: 12px; border: 1px solid var(--border); }
    .qr-placeholder { width: 220px; height: 220px; border: 2px dashed var(--border); border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; color: var(--text-muted); }
    .qr-placeholder svg { width: 40px; height: 40px; opacity: 0.4; }
    .qr-pulse { width: 10px; height: 10px; border-radius: 50%; background: var(--warning); box-shadow: 0 0 0 0 rgba(245,158,11,0.4); animation: pulse 1.5s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(245,158,11,0.4); } 70% { box-shadow: 0 0 0 10px rgba(245,158,11,0); } 100% { box-shadow: 0 0 0 0 rgba(245,158,11,0); } }
    .qr-connected { width: 10px; height: 10px; border-radius: 50%; background: var(--primary); box-shadow: 0 0 0 0 rgba(16,185,129,0.4); animation: pulse-green 2s infinite; }
    @keyframes pulse-green { 0% { box-shadow: 0 0 0 0 rgba(16,185,129,0.4); } 70% { box-shadow: 0 0 0 10px rgba(16,185,129,0); } 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); } }
    .qr-label { font-size: 13px; color: var(--text-muted); margin-top: 12px; }
    .error-box { padding: 12px 16px; border-radius: var(--radius-sm); background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); color: #f87171; font-size: 12px; font-family: monospace; margin-top: 8px; word-break: break-all; }
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); background: var(--bg-card2); }
    tbody td { padding: 12px 16px; font-size: 13px; border-bottom: 1px solid var(--border); vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: rgba(255,255,255,0.02); }
    .sub-active { background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
    .sub-due_soon { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.2); }
    .sub-overdue { background: rgba(239,68,68,0.12); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
    .sub-cancelled { background: rgba(100,116,139,0.1); color: #64748b; border: 1px solid rgba(100,116,139,0.15); }
    input[type="date"], select { background: var(--bg-card2); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text); padding: 8px 12px; font-size: 13px; font-family: inherit; width: 100%; }
    input[type="date"]:focus, select:focus { outline: none; border-color: var(--primary); }
    .form-row { display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap; }
    .form-group { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 140px; }
    .form-label { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; }
    .days-badge { margin-left: 8px; font-size: 12px; }
    .days-overdue { color: #ef4444; }
    .days-soon { color: #f59e0b; }
    .days-ok { color: var(--text-muted); }
    .msg-in { color: var(--primary); font-weight: 600; font-size: 11px; }
    .msg-out { color: var(--secondary); font-weight: 600; font-size: 11px; }
    .msg-text { color: var(--text-dim); max-width: 400px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .empty-state { padding: 40px; text-align: center; color: var(--text-muted); }
    .empty-state svg { width: 40px; height: 40px; opacity: 0.3; margin-bottom: 12px; }
  </style>
</head>
<body>
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="logo">
      <div class="logo-icon">F</div>
      <div>
        <div class="logo-text">Chatisha</div>
        <div class="logo-sub">Admin Panel</div>
      </div>
    </div>
    <nav class="nav">
      <div class="nav-label">Management</div>
      <a href="/admin/tenants" class="nav-link active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Tenants
      </a>
      <a href="/admin/setup-requests" class="nav-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Setup Requests
      </a>
    </nav>
    <div class="sidebar-footer">
      <p>Chatisha Control Plane</p>
    </div>
  </aside>

  <!-- Main -->
  <main class="main">
    <a href="/admin/tenants" class="back-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M19 12H5m7-7l-7 7 7 7"/></svg>
      Back to Tenants
    </a>

    <div class="page-header">
      <div class="page-header-left">
        <h1><%= tenant.name %></h1>
        <p><%= tenant.id %></p>
      </div>
      <div>
        <%
          const statusLower = (tenant.status || 'new').toLowerCase();
        %>
        <span class="badge badge-<%= statusLower %>">
          <span class="dot"></span>
          <%= tenant.status %>
        </span>
      </div>
    </div>

    <div class="grid-2">
      <!-- Tenant Details -->
      <div class="card">
        <div class="card-header">
          <h2>Tenant Details</h2>
        </div>
        <div class="card-body">
          <div class="info-row">
            <div class="info-label">Phone</div>
            <div class="info-value"><%= tenant.phone_number || '—' %></div>
          </div>
          <div class="info-row">
            <div class="info-label">Template</div>
            <div class="info-value normal"><%= tenant.config?.template_type || '—' %></div>
          </div>
          <div class="info-row">
            <div class="info-label">Business</div>
            <div class="info-value normal"><%= tenant.config?.business_name || '—' %></div>
          </div>
          <div class="info-row">
            <div class="info-label">Language</div>
            <div class="info-value normal"><%= tenant.config?.language || '—' %></div>
          </div>
          <div class="info-row">
            <div class="info-label">Worker</div>
            <div class="info-value normal">
              <% const workerStatus = (tenant.worker_process?.status || 'stopped').toLowerCase(); %>
              <span class="badge badge-<%= workerStatus %>">
                <span class="dot"></span>
                <%= tenant.worker_process?.status || 'N/A' %>
              </span>
              <span style="color: var(--text-muted); font-size: 12px; margin-left: 6px;"><%= tenant.worker_process?.pm2_name || '' %></span>
            </div>
          </div>
          <div class="info-row">
            <div class="info-label">Session</div>
            <div class="info-value normal">
              <% const sessionState = (tenant.whatsapp_session?.state || 'disconnected').toLowerCase(); %>
              <span class="badge badge-<%= sessionState %>">
                <span class="dot"></span>
                <%= tenant.whatsapp_session?.state || 'N/A' %>
              </span>
            </div>
          </div>
          <div class="info-row">
            <div class="info-label">Last Seen</div>
            <div class="info-value normal" style="color: var(--text-dim); font-size: 13px;">
              <%
                const lastSeen = tenant.whatsapp_session?.last_seen_at;
                const secondsAgo = lastSeen ? Math.floor((Date.now() - new Date(lastSeen).getTime()) / 1000) : null;
                let lastSeenText = 'Never';
                if (secondsAgo !== null) {
                  if (secondsAgo < 60) lastSeenText = secondsAgo + 's ago';
                  else if (secondsAgo < 3600) lastSeenText = Math.floor(secondsAgo / 60) + 'm ago';
                  else lastSeenText = Math.floor(secondsAgo / 3600) + 'h ago';
                }
              %>
              <%= lastSeenText %>
              <% if (tenant.whatsapp_session?.last_seen_at) { %>
                <span style="color: var(--text-muted); font-size: 12px;">(<%= new Date(tenant.whatsapp_session.last_seen_at).toLocaleString() %>)</span>
              <% } %>
            </div>
          </div>
          <% if (tenant.worker_process?.last_error) { %>
          <div class="info-row">
            <div class="info-label">Last Error</div>
            <div class="info-value">
              <div class="error-box"><%= tenant.worker_process.last_error %></div>
            </div>
          </div>
          <% } %>

          <div class="worker-actions">
            <% if (tenant.worker_process?.status !== 'RUNNING') { %>
              <button class="btn btn-success" onclick="workerAction('start')">
                <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                Start Worker
              </button>
            <% } else { %>
              <button class="btn btn-danger" onclick="workerAction('stop')">
                <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><rect x="6" y="6" width="12" height="12" rx="1"/></svg>
                Stop Worker
              </button>
              <button class="btn btn-warning" onclick="workerAction('restart')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
                Restart
              </button>
            <% } %>
            <% if (tenant.status === 'ERROR') { %>
              <button class="btn btn-danger" onclick="workerAction('force-restart', true)">Force Restart</button>
            <% } %>
          </div>
        </div>
      </div>

      <!-- QR Code -->
      <div class="card">
        <div class="card-header">
          <h2>WhatsApp Session</h2>
          <% if (tenant.status === 'QR_PENDING') { %>
            <div style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--warning);">
              <div class="qr-pulse"></div> Waiting for scan
            </div>
          <% } else if (tenant.status === 'ACTIVE') { %>
            <div style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--primary);">
              <div class="qr-connected"></div> Connected
            </div>
          <% } %>
        </div>
        <div class="qr-container">
          <% if (tenant.whatsapp_session?.last_qr) { %>
            <img src="<%= tenant.whatsapp_session.last_qr %>" alt="QR Code">
            <p class="qr-label">Scan with WhatsApp to connect</p>
          <% } else { %>
            <div class="qr-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h.01M14 17h3M17 14v3M17 17h3v3h-3v-3z"/>
              </svg>
              <% if (tenant.status === 'QR_PENDING') { %>
                <span style="font-size:13px;color:var(--warning);">Generating QR...</span>
              <% } else if (tenant.status === 'ACTIVE') { %>
                <span style="font-size:13px;color:var(--primary);">Connected</span>
              <% } else { %>
                <span style="font-size:13px;">Start worker to get QR</span>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Subscription Management -->
    <div class="card">
      <div class="card-header">
        <h2>Subscription &amp; Billing</h2>
        <%
          const subStatus = tenant.subscription_status || 'ACTIVE';
          const endDate = tenant.subscription_end_date ? new Date(tenant.subscription_end_date) : null;
          const daysLeft = endDate ? Math.ceil((endDate - Date.now()) / (1000 * 60 * 60 * 24)) : null;
          let subClass = 'sub-active';
          let subLabel = subStatus;
          if (subStatus === 'CANCELLED') { subClass = 'sub-cancelled'; }
          else if (daysLeft !== null && daysLeft < 0) { subClass = 'sub-overdue'; subLabel = 'OVERDUE'; }
          else if (daysLeft !== null && daysLeft <= 5) { subClass = 'sub-due_soon'; subLabel = 'DUE SOON'; }
        %>
        <span class="badge <%= subClass %>"><span class="dot"></span><%= subLabel %></span>
      </div>
      <div class="card-body">
        <div class="info-row">
          <div class="info-label">Status</div>
          <div class="info-value normal"><%= subStatus %></div>
        </div>
        <div class="info-row">
          <div class="info-label">End Date</div>
          <div class="info-value normal">
            <% if (endDate) { %>
              <%= endDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
              <% if (daysLeft !== null) { %>
                <%
                  const daysClass = daysLeft < 0 ? 'days-overdue' : daysLeft <= 5 ? 'days-soon' : 'days-ok';
                  const daysText = daysLeft < 0 ? Math.abs(daysLeft) + ' days overdue' : daysLeft === 0 ? 'due today' : daysLeft + ' days left';
                %>
                <span class="days-badge <%= daysClass %>">(<%= daysText %>)</span>
              <% } %>
            <% } else { %>
              <span style="color:var(--text-muted);">Not set</span>
            <% } %>
          </div>
        </div>
        <% if (endDate && daysLeft !== null && daysLeft <= 5 && tenant.phone_number) { %>
        <div class="info-row">
          <div class="info-label">Reminder</div>
          <div class="info-value normal">
            <a class="btn btn-success" target="_blank"
               href="https://wa.me/<%= tenant.phone_number.replace(/[^0-9]/g,'') %>?text=<%= encodeURIComponent('Habari ' + tenant.name + '! Kumbukumbu ya malipo ya Chatisha yako. Huduma yako itakwisha tarehe ' + endDate.toLocaleDateString('en-GB') + '. Tafadhali fanya malipo ili kuendelea. Asante! — Chatisha Team') %>">
              📱 Send WhatsApp Reminder
            </a>
          </div>
        </div>
        <% } %>

        <form method="POST" action="/admin/tenants/<%= tenant.id %>/subscription" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Payment End Date</label>
              <input type="date" name="subscription_end_date"
                value="<%= endDate ? endDate.toISOString().split('T')[0] : '' %>"
                min="<%= new Date().toISOString().split('T')[0] %>">
            </div>
            <div class="form-group">
              <label class="form-label">Subscription Status</label>
              <select name="subscription_status">
                <option value="ACTIVE" <%= subStatus === 'ACTIVE' ? 'selected' : '' %>>Active</option>
                <option value="CANCELLED" <%= subStatus === 'CANCELLED' ? 'selected' : '' %>>Cancelled</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary" style="align-self:flex-end;white-space:nowrap;">Save Payment</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Messages -->
    <div class="card">
      <div class="card-header">
        <h2>Recent Messages</h2>
        <span style="font-size:12px;color:var(--text-muted);">Last 50</span>
      </div>
      <% if (logs.length === 0) { %>
        <div class="empty-state">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
          <p>No messages yet</p>
        </div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Time</th>
              <th>Direction</th>
              <th>From</th>
              <th>To</th>
              <th>Message</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(function(log) { %>
            <tr>
              <td style="color:var(--text-muted);font-size:12px;white-space:nowrap;"><%= new Date(log.created_at).toLocaleString() %></td>
              <td><span class="msg-<%= log.direction.toLowerCase() %>"><%= log.direction %></span></td>
              <td style="color:var(--text-dim);font-size:13px;"><%= log.from_number %></td>
              <td style="color:var(--text-dim);font-size:13px;"><%= log.to_number %></td>
              <td class="msg-text"><%= log.message_text %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>
  </main>

  <script>
    const tenantId = '<%= tenant.id %>';

    async function workerAction(action, confirm_) {
      if (confirm_ && !confirm('This will force-restart the worker. Continue?')) return;
      const res = await fetch('/admin/tenants/' + tenantId + '/worker/' + action, { method: 'POST' });
      if (res.ok) window.location.reload();
      else alert('Failed: ' + action);
    }

    const tenantStatus = '<%= tenant.status %>';
    if (tenantStatus === 'QR_PENDING') {
      setInterval(async () => {
        const res = await fetch('/admin/tenants/' + tenantId + '/qr');
        const data = await res.json();
        if (data.qr) window.location.reload();
      }, 5000);
    }
  </script>
</body>
</html>
