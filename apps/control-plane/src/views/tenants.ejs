<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chatisha Admin — Tenants</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #080d18; --bg-card: #0d1625; --bg-card2: #111c2e;
      --border: rgba(255,255,255,0.07); --primary: #10b981;
      --primary-dim: rgba(16,185,129,0.12); --primary-border: rgba(16,185,129,0.25);
      --secondary: #8b5cf6; --danger: #ef4444; --danger-dim: rgba(239,68,68,0.12);
      --warning: #f59e0b; --warning-dim: rgba(245,158,11,0.12);
      --text: #e2e8f0; --text-muted: #64748b; --text-dim: #94a3b8;
      --radius: 12px; --radius-sm: 8px;
    }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; }
    .sidebar { width: 240px; min-height: 100vh; background: var(--bg-card); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 10; }
    .logo { display: flex; align-items: center; gap: 12px; padding: 24px 20px; border-bottom: 1px solid var(--border); }
    .logo-icon { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, #10b981, #059669); display: flex; align-items: center; justify-content: center; font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 18px; color: white; flex-shrink: 0; box-shadow: 0 0 20px rgba(16,185,129,0.3); }
    .logo-text { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 16px; color: white; }
    .logo-sub { font-size: 10px; color: var(--text-muted); font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; }
    .nav { padding: 16px 12px; flex: 1; }
    .nav-label { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; padding: 0 8px; margin-bottom: 8px; margin-top: 16px; }
    .nav-link { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: var(--radius-sm); color: var(--text-dim); text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.15s; margin-bottom: 2px; border: 1px solid transparent; }
    .nav-link:hover { background: rgba(255,255,255,0.05); color: var(--text); }
    .nav-link.active { background: var(--primary-dim); color: var(--primary); border-color: var(--primary-border); }
    .nav-link svg { width: 16px; height: 16px; flex-shrink: 0; }
    .nav-badge { margin-left: auto; background: #ef4444; color: white; border-radius: 20px; font-size: 10px; font-weight: 700; padding: 2px 7px; min-width: 18px; text-align: center; line-height: 1.4; }
    .signout-link { display: flex; align-items: center; gap: 6px; margin-top: 12px; padding: 8px 10px; border-radius: var(--radius-sm); color: var(--text-muted); text-decoration: none; font-size: 12px; font-weight: 500; border: 1px solid var(--border); transition: all 0.15s; }
    .signout-link:hover { color: var(--danger); border-color: rgba(239,68,68,0.3); background: var(--danger-dim); }
    .signout-link svg { width: 14px; height: 14px; flex-shrink: 0; }
    .sidebar-footer { padding: 16px 20px; border-top: 1px solid var(--border); }
    .sidebar-footer p { font-size: 11px; color: var(--text-muted); }
    .main { margin-left: 240px; flex: 1; padding: 32px; min-height: 100vh; }
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-family: 'Space Grotesk', sans-serif; font-size: 24px; font-weight: 700; color: white; }
    .page-header p { color: var(--text-muted); font-size: 14px; margin-top: 4px; }
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
    .stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
    .stat-label { font-size: 12px; color: var(--text-muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }
    .stat-value { font-family: 'Space Grotesk', sans-serif; font-size: 28px; font-weight: 700; color: white; margin-top: 8px; }
    .stat-value.green { color: var(--primary); }
    .stat-value.purple { color: var(--secondary); }
    .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 24px; overflow: hidden; }
    .card-header { padding: 18px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .card-header h2 { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 600; color: white; }
    .card-body { padding: 24px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
    .form-group label { display: block; font-size: 13px; font-weight: 500; color: var(--text-dim); margin-bottom: 6px; }
    .form-group input, .form-group select { width: 100%; padding: 10px 12px; background: var(--bg-card2); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text); font-size: 14px; font-family: inherit; transition: border-color 0.15s; }
    .form-group input:focus, .form-group select:focus { outline: none; border-color: var(--primary); }
    .form-group select option { background: var(--bg-card2); }
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); background: var(--bg-card2); }
    tbody td { padding: 14px 16px; font-size: 14px; border-bottom: 1px solid var(--border); vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: rgba(255,255,255,0.02); }
    .tenant-name a { color: white; text-decoration: none; font-weight: 500; }
    .tenant-name a:hover { color: var(--primary); }
    .badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; letter-spacing: 0.03em; }
    .badge-new { background: rgba(100,116,139,0.15); color: #94a3b8; border: 1px solid rgba(100,116,139,0.2); }
    .badge-qr_pending { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.2); }
    .badge-active { background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
    .badge-paused { background: rgba(139,92,246,0.12); color: #8b5cf6; border: 1px solid rgba(139,92,246,0.2); }
    .badge-error { background: rgba(239,68,68,0.12); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
    .badge-connected { background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
    .badge-disconnected { background: rgba(100,116,139,0.1); color: #64748b; border: 1px solid rgba(100,116,139,0.15); }
    .badge-qr_ready { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.2); }
    .badge-running { background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
    .badge-stopped { background: rgba(100,116,139,0.1); color: #64748b; border: 1px solid rgba(100,116,139,0.15); }
    .badge-stale { background: rgba(239,68,68,0.12); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); margin-left: 4px; }
    .badge-overdue { background: rgba(239,68,68,0.12); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
    .badge-due_soon { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.2); }
    .badge-paid { background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
    .badge-no_date { background: rgba(100,116,139,0.1); color: #64748b; border: 1px solid rgba(100,116,139,0.15); }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; display: inline-block; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px; border-radius: var(--radius-sm); font-size: 13px; font-weight: 500; cursor: pointer; border: 1px solid transparent; text-decoration: none; transition: all 0.15s; font-family: inherit; }
    .btn-primary { background: var(--primary); color: white; border-color: var(--primary); }
    .btn-primary:hover { background: #059669; }
    .btn-ghost { background: rgba(255,255,255,0.05); color: var(--text-dim); border-color: var(--border); }
    .btn-ghost:hover { background: rgba(255,255,255,0.08); color: white; }
    .btn-success { background: var(--primary-dim); color: var(--primary); border-color: var(--primary-border); }
    .btn-success:hover { background: rgba(16,185,129,0.2); }
    .btn-danger { background: var(--danger-dim); color: var(--danger); border-color: rgba(239,68,68,0.25); }
    .btn-danger:hover { background: rgba(239,68,68,0.2); }
    .btn-warning { background: var(--warning-dim); color: var(--warning); border-color: rgba(245,158,11,0.25); }
    .btn-warning:hover { background: rgba(245,158,11,0.2); }
    .btn-sm { padding: 5px 10px; font-size: 12px; }
    .actions-cell { display: flex; gap: 6px; flex-wrap: wrap; }
    .empty-state { padding: 48px; text-align: center; color: var(--text-muted); }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="logo">
      <div class="logo-icon">F</div>
      <div>
        <div class="logo-text">Chatisha</div>
        <div class="logo-sub">Admin Panel</div>
      </div>
    </div>
    <nav class="nav">
      <div class="nav-label">Management</div>
      <a href="/admin/tenants" class="nav-link active">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        Tenants
      </a>
      <a href="/admin/setup-requests" class="nav-link">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Setup Requests
        <% if (locals.pendingCount > 0) { %><span class="nav-badge"><%= locals.pendingCount %></span><% } %>
      </a>
      <a href="/admin/customers" class="nav-link">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Customers
      </a>
    </nav>
    <div class="sidebar-footer">
      <p>Chatisha &copy; 2026</p>
      <p style="margin-top:2px;">Made in Tanzania 🇹🇿</p>
      <a href="/admin/logout" class="signout-link">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Sign Out
      </a>
    </div>
  </aside>

  <main class="main">
    <div class="page-header">
      <h1>Tenant Management</h1>
      <p>Manage all business clients and their WhatsApp workers</p>
    </div>

    <%
      const total = tenants.length;
      const active = tenants.filter(t => t.status === 'ACTIVE').length;
      const running = tenants.filter(t => t.worker_process && t.worker_process.status === 'RUNNING').length;
      const pending = tenants.filter(t => t.status === 'NEW' || t.status === 'QR_PENDING').length;
    %>
    <div class="stats">
      <div class="stat-card"><div class="stat-label">Total Tenants</div><div class="stat-value"><%= total %></div></div>
      <div class="stat-card"><div class="stat-label">Active</div><div class="stat-value green"><%= active %></div></div>
      <div class="stat-card"><div class="stat-label">Workers Running</div><div class="stat-value green"><%= running %></div></div>
      <div class="stat-card"><div class="stat-label">Pending Setup</div><div class="stat-value purple"><%= pending %></div></div>
    </div>

    <div class="card">
      <div class="card-header"><h2>Create New Tenant</h2></div>
      <div class="card-body">
        <form id="createForm">
          <div class="form-grid">
            <div class="form-group"><label>Business Name</label><input type="text" name="name" placeholder="e.g. Nuru Beauty Salon" required></div>
            <div class="form-group"><label>Phone Number</label><input type="text" name="phone_number" placeholder="+255712345678" required></div>
            <div class="form-group"><label>Template Type</label><select name="template_type"><option value="BOOKING">Booking & Appointments</option><option value="ECOMMERCE">Sales & Orders</option><option value="SUPPORT">Customer Support</option><option value="REAL_ESTATE">Real Estate</option><option value="RESTAURANT">Restaurant & Cafe</option><option value="HEALTHCARE">Healthcare & Clinics</option></select></div>
            <div class="form-group"><label>Display Name</label><input type="text" name="business_name" placeholder="Used in bot responses" required></div>
            <div class="form-group"><label>Language</label><select name="language"><option value="SW">Swahili 🇹🇿</option><option value="EN">English 🇬🇧</option></select></div>
          </div>
          <button type="submit" class="btn btn-primary">+ Create Tenant</button>
        </form>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h2>All Tenants</h2>
        <span style="font-size:13px;color:var(--text-muted);"><%= tenants.length %> total</span>
      </div>
      <% if (tenants.length === 0) { %>
        <div class="empty-state"><p>No tenants yet. Create one above.</p></div>
      <% } else { %>
      <table>
        <thead>
          <tr><th>Business</th><th>Phone</th><th>Status</th><th>Billing</th><th>Session</th><th>Last Seen</th><th>Worker</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% tenants.forEach(tenant => { %>
          <%
            const lastSeen = tenant.whatsapp_session && tenant.whatsapp_session.last_seen_at;
            const secondsAgo = lastSeen ? Math.floor((Date.now() - new Date(lastSeen).getTime()) / 1000) : null;
            let lastSeenText = 'Never';
            if (secondsAgo !== null) {
              if (secondsAgo < 60) lastSeenText = secondsAgo + 's ago';
              else if (secondsAgo < 3600) lastSeenText = Math.floor(secondsAgo / 60) + 'm ago';
              else lastSeenText = Math.floor(secondsAgo / 3600) + 'h ago';
            }
            const isStale = secondsAgo !== null && secondsAgo > 120 && tenant.worker_process && tenant.worker_process.status === 'RUNNING';
            const sessionState = (tenant.whatsapp_session && tenant.whatsapp_session.state ? tenant.whatsapp_session.state : 'DISCONNECTED').toLowerCase();
            const workerStatus = (tenant.worker_process && tenant.worker_process.status ? tenant.worker_process.status : 'STOPPED').toLowerCase();
            const subEnd = tenant.subscription_end_date ? new Date(tenant.subscription_end_date) : null;
            const subDays = subEnd ? Math.ceil((subEnd - Date.now()) / (1000 * 60 * 60 * 24)) : null;
            let billingBadge, billingText;
            if (tenant.subscription_status === 'CANCELLED') { billingBadge = 'badge-no_date'; billingText = 'Cancelled'; }
            else if (!subEnd) { billingBadge = 'badge-no_date'; billingText = 'No date'; }
            else if (subDays < 0) { billingBadge = 'badge-overdue'; billingText = Math.abs(subDays) + 'd overdue'; }
            else if (subDays <= 5) { billingBadge = 'badge-due_soon'; billingText = subDays === 0 ? 'Due today' : subDays + 'd left'; }
            else { billingBadge = 'badge-paid'; billingText = subDays + 'd left'; }
          %>
          <tr>
            <td class="tenant-name"><a href="/admin/tenants/<%= tenant.id %>"><%= tenant.name %></a></td>
            <td style="color:var(--text-muted);font-size:13px;"><%= tenant.phone_number || '—' %></td>
            <td>
              <span class="badge badge-<%= tenant.status.toLowerCase() %>"><span class="dot"></span><%= tenant.status %></span>
              <% if (isStale) { %><span class="badge badge-stale">STALE</span><% } %>
            </td>
            <td>
              <span class="badge <%= billingBadge %>"><span class="dot"></span><%= billingText %></span>
              <% if (subEnd) { %><div style="font-size:11px;color:var(--text-muted);margin-top:3px;"><%= subEnd.toLocaleDateString('en-GB') %></div><% } %>
            </td>
            <td><span class="badge badge-<%= sessionState %>"><%= tenant.whatsapp_session && tenant.whatsapp_session.state ? tenant.whatsapp_session.state : 'N/A' %></span></td>
            <td style="color:var(--text-muted);font-size:13px;"><%= lastSeenText %></td>
            <td>
              <span class="badge badge-<%= workerStatus %>"><span class="dot"></span><%= tenant.worker_process && tenant.worker_process.status ? tenant.worker_process.status : 'N/A' %></span>
              <% if (tenant.worker_process && tenant.worker_process.last_error) { %><span title="<%= tenant.worker_process.last_error %>" style="color:var(--danger);cursor:help;margin-left:4px;">⚠</span><% } %>
            </td>
            <td>
              <div class="actions-cell">
                <% if (!tenant.worker_process || tenant.worker_process.status !== 'RUNNING') { %>
                  <button class="btn btn-success btn-sm" onclick="startWorker('<%= tenant.id %>')">Start</button>
                <% } else { %>
                  <button class="btn btn-danger btn-sm" onclick="stopWorker('<%= tenant.id %>')">Stop</button>
                  <button class="btn btn-warning btn-sm" onclick="restartWorker('<%= tenant.id %>')">Restart</button>
                <% } %>
                <% if (tenant.status === 'ERROR' || isStale) { %>
                  <button class="btn btn-danger btn-sm" onclick="forceRestartWorker('<%= tenant.id %>')">Force</button>
                <% } %>
                <a href="/admin/tenants/<%= tenant.id %>" class="btn btn-ghost btn-sm">View →</a>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </main>

  <script>
    document.getElementById('createForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(e.target));
      const res = await fetch('/admin/tenants', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (res.ok) window.location.reload(); else alert('Failed to create tenant');
    });
    async function startWorker(id) { const r = await fetch('/admin/tenants/'+id+'/worker/start', {method:'POST'}); if(r.ok) window.location.reload(); else alert('Failed'); }
    async function stopWorker(id) { const r = await fetch('/admin/tenants/'+id+'/worker/stop', {method:'POST'}); if(r.ok) window.location.reload(); else alert('Failed'); }
    async function restartWorker(id) { const r = await fetch('/admin/tenants/'+id+'/worker/restart', {method:'POST'}); if(r.ok) window.location.reload(); else alert('Failed'); }
    async function forceRestartWorker(id) { if(!confirm('Force restart worker?')) return; const r = await fetch('/admin/tenants/'+id+'/worker/force-restart', {method:'POST'}); if(r.ok) window.location.reload(); else alert('Failed'); }
  </script>
</body>
</html>
