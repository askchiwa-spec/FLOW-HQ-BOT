# ============================================================
# Chatisha Web App – Environment Example
# Used by: apps/web (Next.js)
# Copy to apps/web/.env.local and fill in your values
# ============================================================

# NextAuth
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-this-to-a-long-random-secret

# Google OAuth (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database (same as control-plane)
DATABASE_URL=postgresql://user:password@localhost:5432/chatisha

# Control Plane internal API
CONTROL_PLANE_URL=http://localhost:3000

# Portal API Security (must match PORTAL_INTERNAL_KEY in control-plane)
PORTAL_INTERNAL_KEY=change-this-to-a-long-random-secret-key
