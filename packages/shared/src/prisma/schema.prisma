generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantStatus {
  NEW
  QR_PENDING
  ACTIVE
  PAUSED
  ERROR
}

enum TemplateType {
  BOOKING
  ECOMMERCE
  SUPPORT
  REAL_ESTATE
  RESTAURANT
  HEALTHCARE
  SALON
  HOTEL
}

enum Language {
  SW
  EN
}

enum SessionState {
  DISCONNECTED
  QR_READY
  CONNECTED
}

enum MessageDirection {
  IN
  OUT
}

enum WorkerStatus {
  RUNNING
  STOPPED
  ERROR
}

enum UserRole {
  OWNER
  STAFF
  ADMIN
}

enum SetupRequestStatus {
  SUBMITTED
  REVIEWING
  APPROVED
  ACTIVE
  REJECTED
}

enum LeadStatus {
  NEW
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum FollowupStatus {
  ACTIVE
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum ScheduledMessageType {
  APPOINTMENT_REMINDER_24H
  APPOINTMENT_REMINDER_2H
  APPOINTMENT_MISSED
  ORDER_FOLLOWUP
}

enum RequestType {
  APPOINTMENT
  ORDER
  ROOM_INQUIRY
  SERVICE_INQUIRY
  GENERAL
}

model Tenant {
  id            String       @id @default(uuid())
  name          String
  phone_number  String
  status        TenantStatus @default(NEW)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  subscription_end_date DateTime?
  subscription_status   String    @default("ACTIVE")

  config              TenantConfig?
  whatsapp_session    WhatsAppSession?
  message_logs        MessageLog[]
  worker_process      WorkerProcess?
  user                User?
  setup_requests      SetupRequest[]
  business_documents  BusinessDocument[]
  conversation_messages ConversationMessage[]
  customers           Customer[]
  appointments        Appointment[]
  order_followups     OrderFollowup[]
  scheduled_messages  ScheduledMessage[]

  @@map("tenants")
}

model TenantConfig {
  id               String       @id @default(uuid())
  tenant_id        String       @unique
  tenant           Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  template_type    TemplateType @default(BOOKING)
  business_name    String
  language         Language     @default(SW)
  hours_json       Json?
  business_context String?      @db.Text
  ai_enabled       Boolean      @default(true)
  website_url      String?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@map("tenant_configs")
}

model WhatsAppSession {
  id            String       @id @default(uuid())
  tenant_id     String       @unique
  tenant        Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  state         SessionState @default(DISCONNECTED)
  last_qr       String?
  last_seen_at  DateTime?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  @@map("whatsapp_sessions")
}

model MessageLog {
  id              String          @id @default(uuid())
  tenant_id       String
  tenant          Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  direction       MessageDirection
  from_number     String
  to_number       String
  message_text    String
  wa_message_id   String?
  created_at      DateTime        @default(now())

  @@index([tenant_id, created_at])
  @@map("message_logs")
}

model WorkerProcess {
  id          String       @id @default(uuid())
  tenant_id   String       @unique
  tenant      Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  pm2_name    String
  status      WorkerStatus @default(STOPPED)
  last_error  String?
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  @@map("worker_processes")
}

model User {
  id            String    @id @default(uuid())
  tenant_id     String?   @unique
  tenant        Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: SetNull)
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          UserRole  @default(OWNER)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  setup_requests SetupRequest[]
  portal_events  PortalEventLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model SetupRequest {
  id              String             @id @default(uuid())
  tenant_id       String
  tenant          Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user_id         String
  user            User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  template_type   TemplateType
  whatsapp_number String
  status          SetupRequestStatus @default(SUBMITTED)
  notes           String?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt

  @@map("setup_requests")
}

model PortalEventLog {
  id          String   @id @default(uuid())
  tenant_id   String
  user_id     String?
  user        User?    @relation(fields: [user_id], references: [id])
  event_type  String
  payload_json Json?
  created_at  DateTime @default(now())

  @@index([tenant_id, created_at])
  @@map("portal_event_logs")
}

model BusinessDocument {
  id           String   @id @default(uuid())
  tenant_id    String
  tenant       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  filename     String
  file_type    String
  file_path    String?
  url          String?
  content_text String?  @db.Text
  created_at   DateTime @default(now())

  @@index([tenant_id])
  @@map("business_documents")
}

model ConversationMessage {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  contact    String
  role       String
  content    String   @db.Text
  created_at DateTime @default(now())

  @@index([tenant_id, contact, created_at])
  @@map("conversation_messages")
}

model Customer {
  id               String      @id @default(cuid())
  tenant_id        String
  tenant           Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  phone            String
  name             String?
  request_type     RequestType @default(GENERAL)
  lead_status      LeadStatus  @default(NEW)
  created_at       DateTime    @default(now())
  last_interaction DateTime    @default(now())

  @@unique([tenant_id, phone])
  @@index([tenant_id, lead_status])
  @@map("customers")
}

model Appointment {
  id               String            @id @default(uuid())
  tenant_id        String
  tenant           Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  contact_phone    String
  contact_name     String?
  service          String?
  appointment_at   DateTime?
  status           AppointmentStatus @default(PENDING)
  reminder_24h_sent Boolean          @default(false)
  reminder_2h_sent  Boolean          @default(false)
  missed_sent       Boolean          @default(false)
  raw_text         String?           @db.Text
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  scheduled_messages ScheduledMessage[]

  @@index([tenant_id, appointment_at])
  @@index([tenant_id, contact_phone])
  @@map("appointments")
}

model OrderFollowup {
  id              String         @id @default(uuid())
  tenant_id       String
  tenant          Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  contact_phone   String
  order_summary   String?        @db.Text
  status          FollowupStatus @default(ACTIVE)
  followup_count  Int            @default(0)
  next_followup_at DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  scheduled_messages ScheduledMessage[]

  @@index([tenant_id, status, next_followup_at])
  @@index([tenant_id, contact_phone])
  @@map("order_followups")
}

model ScheduledMessage {
  id             String               @id @default(uuid())
  tenant_id      String
  tenant         Tenant               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  contact_phone  String
  message        String               @db.Text
  type           ScheduledMessageType
  send_at        DateTime
  sent_at        DateTime?
  appointment_id String?
  appointment    Appointment?         @relation(fields: [appointment_id], references: [id], onDelete: SetNull)
  followup_id    String?
  followup       OrderFollowup?       @relation(fields: [followup_id], references: [id], onDelete: SetNull)
  created_at     DateTime             @default(now())

  @@index([tenant_id, send_at, sent_at])
  @@map("scheduled_messages")
}
